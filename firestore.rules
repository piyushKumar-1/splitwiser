rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    // - Any authenticated user can read (for search)
    // - Users can write their own doc (self-registration)
    // - Users can create docs for others with registered=false (manual add)
    match /users/{email} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && (request.auth.token.email == email
                       || resource == null && request.resource.data.registered == false);
    }
  }
}
